# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Supabase PostgreSQL/PostGIS
# Dejar DB_HOST vacío permite arrancar con SQLite durante la preparación local.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require
# Activar solo para pruebas locales sin tocar Supabase.
USE_SQLITE=False

# Rutas locales opcionales de GeoDjango en Windows/OSGeo4W.
# Ajustar el nombre de GDAL a la version instalada.
GDAL_LIBRARY_PATH=C:\\OSGeo4W\\bin\\gdalXXX.dll
GEOS_LIBRARY_PATH=C:\\OSGeo4W\\bin\\geos_c.dll
GDAL_DATA=C:\\OSGeo4W\\share\\gdal
PROJ_DATA=C:\\OSGeo4W\\share\\proj

# Supabase API y Storage. Nunca exponer la service role key al navegador.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=emergency-evidence
MAX_AUDIO_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5
PUBLIC_ALERT_RATE_LIMIT=5
PUBLIC_ALERT_RATE_WINDOW_SECONDS=3600
